# ============================================================
# Obsidian — 工作区状态（每人不同，不应共享）
# ============================================================
.obsidian/workspace.json
.obsidian/workspace-mobile.json

# ============================================================
# Obsidian 插件 — 编译代码（体积大，由 Obsidian 自动安装）
# 只保留 data.json（插件设置）+ manifest.json（版本信息）
# ============================================================
.obsidian/plugins/*/main.js
.obsidian/plugins/*/styles.css
.obsidian/plugins/*/obsidian_askpass.sh

# 个人 Claude 集成插件（完全排除）
.obsidian/plugins/realclaudian/

# ============================================================
# Obsidian 日志与自动生成文件
# ============================================================
activity.log
*.base

# ============================================================
# Claude Code 本地配置与个人会话（不共享）
# ============================================================
.claude/settings.local.json
.claudian/
CLAUDE.md

# ============================================================
# 操作系统临时文件
# ============================================================
.DS_Store
Thumbs.db
desktop.ini
